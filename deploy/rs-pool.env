# Runtime environment for rs_pool (sourced by systemd EnvironmentFile=).
# Change RUST_LOG and restart: sudo systemctl restart rs-pool
#
# Examples:
#   RUST_LOG=info
#   RUST_LOG=debug
#   RUST_LOG=rs_pool=debug,warn
#   RUST_LOG=info,rs_pool::mqtt=debug,rs_pool::state=debug
#   RUST_LOG=info,rs_pool::modbus=debug
#   RUST_LOG=trace

RUST_LOG=info

# Optional: override config path (default /etc/rs_pool/config.toml)
# RS_POOL_CONFIG=/etc/rs_pool/config.toml
